{
  "name": "skillfoo",
  "version": "1.0.0",
  "description": "Keep your team's agent skills in one place, synced to every repo.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rawgroundbeef/skillfoo.git"
  },
  "homepage": "https://github.com/rawgroundbeef/skillfoo#readme",
  "bugs": {
    "url": "https://github.com/rawgroundbeef/skillfoo/issues"
  },
  "type": "module",
  "bin": {
    "skillfoo": "dist/entrypoint.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node --eval \"require('node:fs').rmSync('dist', { recursive: true, force: true }); require('node:fs').rmSync('.test-dist', { recursive: true, force: true })\"",
    "typecheck": "tsc -p tsconfig.json",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "test": "npm run build && tsc -p tsconfig.test.json && node --test .test-dist/test/index.js",
    "check": "npm run typecheck && npm test",
    "test:package": "node scripts/verify-package.mjs",
    "prepack": "npm run build"
  },
  "engines": {
    "node": "^22.0.0 || ^24.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "typescript": "~7.0.2"
  }
}
